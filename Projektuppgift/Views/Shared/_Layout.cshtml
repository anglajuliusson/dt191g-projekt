<!DOCTYPE html>
<html lang="sv">
<head>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="header-first">
            <picture>
                <source srcset="~/images/logo.webp" type="image/webp">
                <source srcset="~/images/logo.avif" type="image/avif">
                <img src="~/images/logo.png" alt="Arvidsjaur kommun logotyp">
            </picture>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form class="login" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" style="display:inline;">
                <button type="submit" class="logout">Logga ut</button>
            </form>
        }
        else
        {
            <a class="login" asp-area="Identity" asp-page="/Account/Login">Logga in</a>
        }
        </div>
        <div class="header-second">
            <nav>
                <ul>
                    <li><a asp-controller="Home" asp-action="Index">Startsida</a></li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li><a asp-controller="Associations" asp-action="Index">Föreningar</a></li>
                    } else {                    
                        <li><a asp-controller="Home" asp-action="Associations">Föreningar</a></li>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li><a asp-controller="Facilities" asp-action="Index">Lokaler</a></li>
                    } else {
                        <li><a asp-controller="Home" asp-action="Facilities">Lokaler</a></li>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li><a asp-controller="Bookings" asp-action="Index">Bokningar</a></li>
                    } else {
                        <li><a asp-controller="Home" asp-action="Bookings">Bokningar</a></li>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li><a asp-controller="Bookings" asp-action="Create">Gör bokning</a></li>
                    }
                </ul>
            </nav>
        </div>
    </header>
    <main>
        @RenderBody()
    </main>
    <footer>
        <h3>Kontaktinformation</h3>
        <p>Arvidsjaur kommun</p>
        <P>Postadress: 933 31 Arvidsjaur</P>
        <p>Besöksadress: Storgatan 13</p>
        <p>Telefonväxel: 0960-155 00</p>
        <p>E-post: kommun@arvidsjaur.se</p>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>