@model Projektuppgift.Models.Booking

@{
    ViewData["Title"] = "Redigera bokning";
}

<section class="edit">
    <h2>Redigera bokning</h2>

    <div class="row">
        <div class="col-md-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="BookingId" />
                <div class="form-group">
                    <label asp-for="FacilityId" class="control-label">Lokal</label>
                    <select asp-for="FacilityId" class="form-control" asp-items="ViewBag.FacilityId"></select>
                    <span asp-validation-for="FacilityId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="AssociationId" class="control-label">Förening</label>
                    <select asp-for="AssociationId" class="form-control" asp-items="ViewBag.AssociationId"></select>
                    <span asp-validation-for="AssociationId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="StartDateTime" class="control-label">Från</label>
                    <input asp-for="StartDateTime" class="form-control" />
                    <span asp-validation-for="StartDateTime" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="EndDateTime" class="control-label">Till</label>
                    <input asp-for="EndDateTime" class="form-control" />
                    <span asp-validation-for="EndDateTime" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Status" class="control-label"></label>
                    <input asp-for="Status" class="form-control" />
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <input type="submit" value="Spara ändringar" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>

    <div class="back-link-div">
        <a class="back-link" asp-action="Index">Tillbaka</a>
    </div>
</section>