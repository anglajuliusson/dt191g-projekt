@model Projektuppgift.Models.Booking

@{
    ViewData["Title"] = "Radera bokning";
}

<main class="delete">
    <h2>Radera bokning</h2>

    <h3>Är du säker på att du vill radera denna bokning?</h3>
    <div>
        <dl class="row">
            <dt class = "col-sm-2">Lokal:</dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Facility.Name)
            </dd>
            <dt class = "col-sm-2">Förening:</dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Association.Name)
            </dd>
            <dt class = "col-sm-2">Från:</dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.StartDateTime)
            </dd>
            <dt class = "col-sm-2">Till:</dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.EndDateTime)
            </dd>
            <dt class = "col-sm-2">
                @Html.DisplayNameFor(model => model.Status)
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Status)
            </dd>
        </dl>
        
        <form asp-action="Delete">
            <input type="hidden" asp-for="BookingId" />
            <input type="submit" value="Radera" class="btn btn-danger" /> |
            <a class="back-link" asp-action="Index">Tillbaka</a>
        </form>
    </div>
</main>