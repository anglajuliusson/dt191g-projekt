@model Projektuppgift.Models.Booking

@{
    ViewData["Title"] = "Detaljer";
}
<main class="details">
    <h2>Detaljer</h2>

    <div>
        <dl class="row">
            <dt class = "col-sm-2">Lokal:</dt>
            <dd class = "col-sm-10">
                @(Model.Facility?.Name ?? "Saknas")
            </dd>
            <dt class = "col-sm-2">Förening:</dt>
            <dd class = "col-sm-10">
                @(Model.Association?.Name ?? "Saknas")
            </dd>
            <dt class = "col-sm-2">Från:</dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.StartDateTime)
            </dd>
            <dt class = "col-sm-2">Till:</dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.EndDateTime)
            </dd>
            <dt class = "col-sm-2">
                @Html.DisplayNameFor(model => model.Status)
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Status)
            </dd>
        </dl>
    </div>
    <div class="back-link-div">
        <a class="edit-link" asp-action="Edit" asp-route-id="@Model?.BookingId">Redigera</a> |
        <a class="back-link" asp-action="Index">Tillbaka</a>
    </div>
</main>