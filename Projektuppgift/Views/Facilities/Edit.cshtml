@model Projektuppgift.Models.Facility

@{
    ViewData["Title"] = "Redigera lokal";
}
<main class="edit">
    <h2>Redigera lokal</h2>

    <div class="row">
        <div class="col-md-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="FacilityId" />
                <div class="form-group">
                    <label asp-for="Name" class="control-label">Namn: </label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Address" class="control-label">Adress: </label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Description" class="control-label">Beskrivning: </label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <input type="submit" value="Spara ändringar" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>

    <div class="back-link-div">
        <a class="back-link" asp-action="Index">Tillbaka</a>
    </div>

    @section Scripts {
        @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    }
</main>