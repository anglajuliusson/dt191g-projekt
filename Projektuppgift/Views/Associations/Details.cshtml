@model Projektuppgift.Models.Association

@{
    ViewData["Title"] = "Details";
}

<main class="details">
    <h2>Detaljer</h2>

    <div>
        <dl class="row">
            <dt class = "col-sm-2">Föreningsnamn: </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Name)
            </dd>
            <dt class = "col-sm-2">E-postadress: </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.ContactEmail)
            </dd>
        </dl>
    </div>
    <div class="back-link-div">
        <a class="edit-link" asp-action="Edit" asp-route-id="@Model?.AssociationId">Redigera</a> |
        <a class="back-link" asp-action="Index">Tillbaka</a>
    </div>
</main>